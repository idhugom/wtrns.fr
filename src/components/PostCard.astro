---
import Thumb from './Thumb.astro';
const { post, delay = 0, featured = false } = Astro.props;
const badgeClass = `badge--${post.color === 'orange' || post.color === 'violet' ? 'pink' : post.color}`;
---
<a href={post.href} class={`card ${featured ? 'card--featured' : ''}`} data-reveal data-delay={delay}>
  <div class="card__media">
    <span class={`badge ${badgeClass} card__badge`}>{post.topicLabel}</span>
    <Thumb post={post} w={600} h={400} />
  </div>
  <div class="card__body">
    <h3 class="card__title">{post.title}</h3>
    {featured && post.excerpt && <p class="card__excerpt">{post.excerpt}</p>}
    <div class="card__foot">
      <span class="mono">{post.hasContent ? 'Guide complet' : 'Bientôt'} · {post.reading || 8} min</span>
      <span class="card__arrow" aria-hidden="true">↗</span>
    </div>
  </div>
</a>

<style>
  .card--featured { grid-column: span 2; }
  .card--featured .card__title { font-size: clamp(1.4rem, 2.6vw, 2rem); }
  .card--featured .card__media { aspect-ratio: 16/9; }
  .card__ph { width: 100%; height: 100%; display: grid; place-items: center; }
  .card__ph span { font-family: var(--font-display); font-weight: 900; font-size: 5rem; opacity: .5; }
  @media (max-width: 640px) { .card--featured { grid-column: span 1; } }
</style>
