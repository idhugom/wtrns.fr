---
import Base from '../layouts/Base.astro';
import { allPosts, topicsSummary } from '../lib/posts.js';
const total = allPosts.length;
const topics = topicsSummary();
---
<Base title="À propos — WTRNS" description="WTRNS, c’est le mag qui transforme n’importe quel sujet en guide clair, complet et actionnable. Notre méthode, notre promesse.">
  <section class="ap-hero wrap">
    <p class="eyebrow" data-reveal><span class="dot"></span> Qui sommes-nous</p>
    <h1 data-reveal>On fait des guides<br/>qui <span class="hl">pettent</span>.</h1>
    <p class="ap-lead" data-reveal>WTRNS transforme des recherches banales en guides de référence. Pas de contenu creux, pas de blabla&nbsp;: de l’info triée, vérifiée, mise en forme pour que tu trouves ta réponse en quelques secondes.</p>
  </section>

  <section class="ap-stats wrap-wide">
    <div class="ap-stat c-lime" data-reveal><b>{total}</b><span>guides publiés</span></div>
    <div class="ap-stat c-cyan" data-reveal data-delay="1"><b>{topics.length}</b><span>thématiques</span></div>
    <div class="ap-stat c-pink" data-reveal data-delay="2"><b>100%</b><span>fait pour agir</span></div>
    <div class="ap-stat c-yellow" data-reveal data-delay="3"><b>0</b><span>blabla inutile</span></div>
  </section>

  <section class="ap-method wrap">
    <h2 data-reveal>Notre <span class="u-underline">méthode</span></h2>
    <div class="ap-cards">
      <div class="ap-card" data-reveal><span class="num">01</span><h3>Comprendre l’intention</h3><p>On identifie ce que tu cherches vraiment derrière ta requête — et on y répond entièrement.</p></div>
      <div class="ap-card" data-reveal data-delay="1"><span class="num">02</span><h3>Structurer l’info</h3><p>Tableaux comparatifs, encadrés « à retenir », FAQ&nbsp;: l’essentiel est repérable d’un coup d’œil.</p></div>
      <div class="ap-card" data-reveal data-delay="2"><span class="num">03</span><h3>Rendre actionnable</h3><p>Des étapes concrètes et des critères de choix pour que tu repartes avec une vraie décision.</p></div>
    </div>
  </section>

  <section class="wrap">
    <div class="ap-cta" data-reveal>
      <h2>Prêt à explorer&nbsp;?</h2>
      <a href="/articles" class="btn btn--lime">Voir les {total} guides →</a>
    </div>
  </section>

  <style>
    .ap-hero { padding-block: clamp(2.5rem, 6vw, 4.5rem) 2rem; text-align: center; }
    .ap-hero h1 { font-size: clamp(2.6rem, 8vw, 6rem); }
    .eyebrow .dot { display:inline-block; width:9px;height:9px;border-radius:50%;background:var(--pink);margin-right:.4rem; }
    .hl { background: var(--lime); padding: 0 .12em; border: 3px solid var(--ink); border-radius: 8px; box-shadow: var(--shadow-sm); }
    .ap-lead { max-width: 60ch; margin: 1.4rem auto 0; font-size: 1.2rem; color: #333; }

    .ap-stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; padding-block: 1rem 3rem; }
    .ap-stat { border: var(--bd) solid var(--ink); border-radius: var(--radius); box-shadow: var(--shadow); padding: 1.4rem; display: flex; flex-direction: column; }
    .ap-stat b { font-family: var(--font-display); font-size: clamp(2.4rem, 6vw, 3.6rem); line-height: 1; }
    .ap-stat span { font-family: var(--font-mono); text-transform: uppercase; letter-spacing: .06em; font-size: .78rem; margin-top: .3rem; }
    @media (min-width: 760px) { .ap-stats { grid-template-columns: repeat(4, 1fr); } }

    .ap-method { padding-block: 2rem 3rem; }
    .ap-method h2 { text-align: center; margin-bottom: 2rem; }
    .ap-cards { display: grid; grid-template-columns: 1fr; gap: 1.4rem; }
    .ap-card { background: var(--white); border: var(--bd) solid var(--ink); border-radius: var(--radius); box-shadow: var(--shadow); padding: 1.6rem; }
    .ap-card .num { font-family: var(--font-display); font-weight: 900; font-size: 2.4rem; -webkit-text-stroke: 2px var(--ink); color: transparent; }
    .ap-card h3 { margin: .4rem 0 .5rem; }
    @media (min-width: 800px) { .ap-cards { grid-template-columns: repeat(3, 1fr); } }

    .ap-cta { text-align: center; background: var(--ink); color: var(--paper); border-radius: var(--radius); padding: clamp(2rem, 5vw, 3.5rem); margin-top: 1rem; }
    .ap-cta h2 { color: var(--paper); margin-bottom: 1.2rem; }
  </style>
</Base>
